generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ItemStatus {
  COOLING
  BOUGHT
  SKIPPED
}

enum ExpenseType {
  INSTANT
  PROPOSAL
}

enum ExpenseStatus {
  COOLING
  COMMITTED
  CANCELLED
}

enum Reaction {
  IN
  SKIP
}

enum InviteStatus {
  PENDING
  ACTIVE
}

enum TimeCostMode {
  SIMPLE
  TRUE_HOURLY
}

model User {
  id                      String       @id  // set to Supabase auth UUID on create — enables RLS
  name                    String
  email                   String       @unique
  avatarUrl               String?
  monthlyIncomeCents      Int?
  workingHoursPerWeek     Float?
  commuteHours            Float?
  workCostsCents          Int?
  timeCostMode            TimeCostMode @default(SIMPLE)
  defaultCoolingPeriod    String       @default("1d")
  currency                String       @default("MYR")
  notifyCoolingReady      Boolean      @default(true)
  notifyGroupActivity     Boolean      @default(true)
  notifyMilestoneUnlocked Boolean      @default(true)
  createdAt               DateTime     @default(now())

  items             Item[]
  groupsCreated     Group[]
  groupMembers      GroupMember[]
  expensesPaid      Expense[]
  expenseShares     ExpenseShare[]
  guestMembersAdded GuestMember[]  @relation("GuestMembersAdded")
}

model Item {
  id           String     @id @default(cuid())
  userId       String
  groupId      String?
  title        String
  amountCents  Int
  category     String?
  note         String?
  photoUrl     String?
  linkUrl      String?
  status       ItemStatus @default(COOLING)
  coolingUntil DateTime
  createdAt    DateTime   @default(now())
  resolvedAt   DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([userId, status, coolingUntil])
  @@index([userId, status, resolvedAt])
  @@index([groupId, status])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  creator      User          @relation(fields: [createdBy], references: [id])
  members      GroupMember[]
  items        Item[]
  expenses     Expense[]
  guestMembers GuestMember[]

  @@index([createdBy])
}

model GroupMember {
  id       String       @id @default(cuid())
  groupId  String
  userId   String
  status   InviteStatus @default(ACTIVE)
  invitedBy String?
  joinedAt DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, status])
}

model Expense {
  id           String        @id @default(cuid())
  groupId      String
  payerId      String
  amountCents  Int
  description  String
  type         ExpenseType
  status       ExpenseStatus @default(COMMITTED)
  coolingUntil DateTime?
  createdAt    DateTime      @default(now())

  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer       User              @relation(fields: [payerId], references: [id])
  shares      ExpenseShare[]
  guestShares GuestExpenseShare[]

  @@index([groupId, status, createdAt])
  @@index([payerId])
}

model GuestMember {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  addedBy   String
  createdAt DateTime @default(now())

  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedByUser User              @relation("GuestMembersAdded", fields: [addedBy], references: [id], onDelete: Cascade)
  expenseShares GuestExpenseShare[]

  @@index([groupId])
}

model GuestExpenseShare {
  id         String @id @default(cuid())
  expenseId  String
  guestId    String
  shareCents Int

  expense Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  guest   GuestMember @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([expenseId, guestId])
  @@index([guestId])
}

model ExpenseShare {
  id         String    @id @default(cuid())
  expenseId  String
  userId     String
  shareCents Int
  reaction   Reaction?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
}

model RateLimit {
  key         String   @id
  windowStart DateTime
  count       Int

  @@index([windowStart])
}
